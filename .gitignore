## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# Visual Studio cache/options
.vs/
*.cache
*.[Cc]ache

# Build-generated files
*.dll
*.exe
*.pdb
*.ilk
*.obj
*.iobj
*.ipdb
*.log
*.tlog
*.tmp
*.tmp_proj
*.rsp
*.sbr
*.csproj.nuget.dgspec.json
*.csproj.nuget.g.props
*.csproj.nuget.g.targets
project.assets.json
project.lock.json
project.fragment.lock.json

# .NET / NuGet
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
packages/
**/[Pp]ackages/*

# ASP.NET / publish
publish/
wwwroot/

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Logs and temp
*.pidb
*.svclog
*.dbmdl
*.bak
*.swp
*~